{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid"
    },
    "productCode": {
      "type": "string",
      "unique": true
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "isActive": {
      "type": "boolean"
    },
    "isFeaturedNew": {
      "type": "boolean"
    },
    "productImage": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "colors": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::color.color",
      "mappedBy": "product"
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "mappedBy": "products"
    },
    "price": {
      "required": true,
      "type": "decimal"
    },
    "discount": {
      "type": "decimal",
      "default": 0
    },
    "isDiscounted": {
      "type": "boolean",
      "default": false
    },
    "wholesalePrice": {
      "type": "decimal",
      "required": true
    },
    "costPrice": {
      "type": "decimal",
      "private": true
    },
    "hasVariants": {
      "type": "boolean",
      "default": true
    }
  }
}
