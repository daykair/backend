    },
    "contactName": {
      "type": "string"
    },
    "email": {
      "type": "email",
      "required": false
    },
    "phone": {
      "type": "string"
    },
    "address": {
      "type": "text"
    },
    "notes": {
      "type": "text"
    },
    "purchase_orders": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::purchase-order.purchase-order",
      "mappedBy": "supplier"
    }
  }
}
