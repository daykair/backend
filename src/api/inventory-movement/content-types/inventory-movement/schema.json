{
  "kind": "collectionType",
  "collectionName": "inventory_movements",
  "info": {
    "singularName": "inventory-movement",
    "pluralName": "inventory-movements",
    "displayName": "Inventory Movement",
    "description": "Records of inventory loads and unloads"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "color": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::color.color",
      "inversedBy": "inventory_movements"
    },
    "quantity": {
      "type": "integer",
      "required": false
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "IN",
        "OUT"
      ],
      "required": true
    },
    "reason": {
      "type": "string"
    },
    "date": {
      "type": "datetime",
      "required": true
    },
    "performedBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "exchangeRate": {
      "type": "decimal"
    },
    "product": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product.product"
    },
    "items": {
      "type": "json"
    },
    "order": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::order.order"
    },
    "warehouse": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::warehouse.warehouse"
    }
  }
}
